---
import Base from '../layouts/Base.astro'
---

<Base title="Contact" description="Request a quote or get in touch with Skill Tech Control Systems engineering team.">
  <main class="pt-32 pb-20 technical-grid min-h-screen">
    <div class="max-w-screen-2xl mx-auto px-8">

      <!-- Header -->
      <div class="mb-16">
        <span class="text-primary font-label text-sm uppercase tracking-[0.2em] mb-4 block">Request Specification</span>
        <h1 class="text-5xl md:text-7xl font-headline font-bold tracking-tighter text-on-surface max-w-4xl">
          Configure Your Industrial <br/><span class="text-primary-container">Control Interface.</span>
        </h1>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

        <!-- Form -->
        <div class="lg:col-span-7">
          <div class="bg-surface-container-low p-8 md:p-12 rounded-xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 border-t border-r border-primary/20 pointer-events-none"></div>
            <form class="space-y-8">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                  <label class="text-xs font-label uppercase tracking-widest text-outline">Full Name</label>
                  <input class="w-full bg-transparent border-b border-outline-variant focus:border-primary px-0 py-3 text-on-surface placeholder:text-outline/30 focus:ring-0 transition-colors" placeholder="John Doe" type="text" />
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-label uppercase tracking-widest text-outline">Company Name</label>
                  <input class="w-full bg-transparent border-b border-outline-variant focus:border-primary px-0 py-3 text-on-surface placeholder:text-outline/30 focus:ring-0 transition-colors" placeholder="Global Systems Corp" type="text" />
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                  <label class="text-xs font-label uppercase tracking-widest text-outline">Work Email</label>
                  <input class="w-full bg-transparent border-b border-outline-variant focus:border-primary px-0 py-3 text-on-surface placeholder:text-outline/30 focus:ring-0 transition-colors" placeholder="j.doe@company.com" type="email" />
                </div>
                <div class="space-y-2">
                  <label class="text-xs font-label uppercase tracking-widest text-outline">Phone Number</label>
                  <input class="w-full bg-transparent border-b border-outline-variant focus:border-primary px-0 py-3 text-on-surface placeholder:text-outline/30 focus:ring-0 transition-colors" placeholder="+91 97895 44908" type="tel" />
                </div>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-label uppercase tracking-widest text-outline">Project Description &amp; Technical Requirements</label>
                <textarea class="w-full bg-transparent border-b border-outline-variant focus:border-primary px-0 py-3 text-on-surface placeholder:text-outline/30 focus:ring-0 transition-colors resize-none" placeholder="Specify panel dimensions, PLC requirements, environment details (IP ratings), and required completion timeline..." rows="6"></textarea>
              </div>
              <div class="flex items-center justify-between pt-4">
                <div class="flex items-center space-x-2">
                  <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
                  <span class="text-xs text-outline font-label uppercase tracking-tighter">Engineers Available for Review</span>
                </div>
                <button class="bg-primary-container text-on-primary-container px-10 py-4 rounded-lg font-headline font-bold tracking-tight text-lg hover:shadow-[0_0_20px_rgba(0,102,255,0.4)] transition-all active:scale-95" type="submit">
                  Submit Quote Request
                </button>
              </div>
            </form>
          </div>

          <!-- FAQs -->
          <div class="mt-16 space-y-6">
            <h3 class="text-2xl font-headline font-bold text-on-surface">Consultation FAQs</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="p-6 bg-surface-container border border-outline-variant/10 rounded-lg">
                <h4 class="text-primary font-bold mb-2">What is the turnaround for a quote?</h4>
                <p class="text-sm text-on-surface-variant leading-relaxed">Standard requests are processed within 24-48 business hours after technical validation.</p>
              </div>
              <div class="p-6 bg-surface-container border border-outline-variant/10 rounded-lg">
                <h4 class="text-primary font-bold mb-2">Do you provide on-site installation?</h4>
                <p class="text-sm text-on-surface-variant leading-relaxed">Yes, our field engineers provide deployment and commissioning services.</p>
              </div>
              <div class="p-6 bg-surface-container border border-outline-variant/10 rounded-lg">
                <h4 class="text-primary font-bold mb-2">Are your panels UL/CE certified?</h4>
                <p class="text-sm text-on-surface-variant leading-relaxed">All precision assemblies meet or exceed international safety and compliance standards.</p>
              </div>
              <div class="p-6 bg-surface-container border border-outline-variant/10 rounded-lg">
                <h4 class="text-primary font-bold mb-2">Can I provide my own components?</h4>
                <p class="text-sm text-on-surface-variant leading-relaxed">We support full custom builds using customer-specified hardware and PLCs.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-5 space-y-8">
          <!-- Contact Details -->
          <div class="bg-surface-container-high p-8 rounded-xl space-y-8">
            <div>
              <h3 class="text-xs font-label text-outline uppercase tracking-[0.2em] mb-6">Direct Channels</h3>
              <div class="space-y-6">
                <div class="flex items-start space-x-4">
                  <span class="material-symbols-outlined text-primary">call</span>
                  <div>
                    <p class="text-sm text-on-surface-variant mb-1">Technical Support</p>
                    <p class="text-xl font-headline font-medium text-on-surface">+91 97895 44908</p>
                  </div>
                </div>
                <div class="flex items-start space-x-4">
                  <span class="material-symbols-outlined text-primary">mail</span>
                  <div>
                    <p class="text-sm text-on-surface-variant mb-1">Engineering Enquiries</p>
                    <p class="text-xl font-headline font-medium text-on-surface">skilltechcontrolsystems@gmail.com</p>
                  </div>
                </div>
                <div class="flex items-start space-x-4">
                  <span class="material-symbols-outlined text-primary">location_on</span>
                  <div>
                    <p class="text-sm text-on-surface-variant mb-1">Office Address</p>
                    <p class="text-base font-headline font-medium text-on-surface leading-relaxed">
                      Flat No.44, First Floor,<br/>
                      Lakshmi Ganapathy Nagar,<br/>
                      Gangai Amman Kovil Street,<br/>
                      Urappakkam, Chengalpattu – 603 202.<br/>
                      Tamilnadu
                    </p>
                  </div>
                </div>
              </div>
            </div>
            <div class="pt-8 border-t border-outline-variant/20">
              <h3 class="text-xs font-label text-outline uppercase tracking-[0.2em] mb-4">Proprietor</h3>
              <p class="font-headline font-bold text-on-surface text-lg">Rajalakshmi S</p>
            </div>
          </div>

          <!-- Certification Badge -->
          <div class="p-8 bg-surface-container-low border border-primary/10 rounded-xl flex items-center justify-between">
            <div class="flex items-center space-x-4">
              <span class="material-symbols-outlined text-3xl text-tertiary">verified</span>
              <div>
                <p class="text-sm font-bold text-on-surface">ISO 9001:2015 Certified</p>
                <p class="text-xs text-outline">Quality Assurance Architecture</p>
              </div>
            </div>
            <div class="text-xs font-label text-outline-variant border border-outline-variant px-3 py-1 rounded">GSTIN: 33FZBPR7748D1Z5</div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Base>
