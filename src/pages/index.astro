---
import Base from '../layouts/Base.astro'
---

<Base title="Home" description="Precision industrial control systems for oil & gas, manufacturing, and energy sectors.">
  <main class="relative pt-20">
    <!-- Hero Section -->
    <section class="relative min-h-[921px] flex items-center overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern z-0"></div>
      <div class="max-w-screen-2xl mx-auto px-8 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10">
        <div class="lg:col-span-7 space-y-8">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface-container-high border border-outline-variant/20">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            <span class="text-[10px] font-label uppercase tracking-widest text-primary">System Operational</span>
          </div>
          <h1 class="text-6xl md:text-8xl font-headline font-bold leading-[0.9] tracking-tighter text-on-surface">
            Precision Control <br />
            <span class="text-primary">for Industrial</span> <br />
            Excellence
          </h1>
          <p class="text-xl text-on-surface-variant max-w-xl leading-relaxed">
            Engineered solutions for complex automation. We design and build high-performance control panels that define the future of industrial infrastructure.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <button class="px-8 py-4 bg-primary-container text-on-primary-container font-bold rounded-md shadow-[0_0_20px_rgba(0,102,255,0.3)] hover:brightness-110 transition-all">
              Get Quote
            </button>
            <button class="px-8 py-4 bg-surface-container-high text-primary font-bold rounded-md border border-outline-variant/10 hover:bg-surface-container-highest transition-all">
              Explore Specs
            </button>
          </div>
        </div>
        <div class="lg:col-span-5 relative">
          <div class="aspect-square rounded-xl overflow-hidden shadow-2xl border border-outline-variant/20 transform lg:rotate-3">
            <img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBx9X0TzVtIAkN-79KUHqve0rnmZl3qYEr_i4wCKJPYnVC1s3MT5Dn9NyZdgr2W5l6Y0jkwvf285sGVKIhKzIZVYR1NJ-pcYvQfFrfW-MVYstyiva-BQeQ3G5NKDEmSdmdpX4vXfESlmABUD2tktOi-O9wMG7iyXuuqWKTudibYjqpwCl9x1RH7vmum0u9EtERa3NSEbZuXAa9YZtK8yeRUDmqmC3mE53zfPY3xO1XOFAdlFMYoLzC-n5MclxY5Pi9LxVvxJWDyI58" alt="Close-up of a high-tech industrial control panel" />
            <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent"></div>
          </div>
          <div class="absolute -bottom-6 -left-6 glass-card p-6 border border-outline-variant/20 rounded-lg hidden md:block">
            <div class="text-[10px] font-label text-slate-500 uppercase tracking-[0.2em] mb-2">Model SPEC. PA-092</div>
            <div class="flex items-center gap-4">
              <div class="space-y-1">
                <div class="text-2xl font-headline font-bold text-primary">99.9%</div>
                <div class="text-[10px] font-label text-slate-400">UPTIME RATING</div>
              </div>
              <div class="w-px h-10 bg-outline-variant/30"></div>
              <div class="space-y-1">
                <div class="text-2xl font-headline font-bold text-tertiary">ISO</div>
                <div class="text-[10px] font-label text-slate-400">CERTIFIED</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-24 bg-surface-container-low">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
          <div class="space-y-4">
            <h2 class="text-4xl font-headline font-bold tracking-tight">Engineered for Reliability</h2>
            <p class="text-on-surface-variant max-w-xl">Our panels are built with components from industry leaders and tested under extreme conditions to ensure zero-fail performance.</p>
          </div>
          <div class="text-right hidden md:block">
            <span class="text-[10px] font-label text-outline tracking-[0.3em] uppercase">Core Values / 01</span>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="p-10 bg-surface-container-high rounded-xl border border-outline-variant/10 hover:border-primary/30 transition-all group">
            <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-primary/10 text-primary mb-8 group-hover:bg-primary group-hover:text-on-primary transition-all">
              <span class="material-symbols-outlined text-3xl">verified</span>
            </div>
            <h3 class="text-2xl font-headline font-bold mb-4">Unyielding Quality</h3>
            <p class="text-on-surface-variant leading-relaxed">Each panel undergoes a rigorous 48-hour stress test before shipment, ensuring every circuit exceeds industry standards.</p>
          </div>
          <div class="p-10 bg-surface-container-high rounded-xl border border-outline-variant/10 hover:border-tertiary/30 transition-all group">
            <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-tertiary/10 text-tertiary mb-8 group-hover:bg-tertiary group-hover:text-on-tertiary transition-all">
              <span class="material-symbols-outlined text-3xl">security</span>
            </div>
            <h3 class="text-2xl font-headline font-bold mb-4">Safety-First Design</h3>
            <p class="text-on-surface-variant leading-relaxed">Integrated failsafes and physical barriers designed to protect operators and high-value machinery from electrical surges.</p>
          </div>
          <div class="p-10 bg-surface-container-high rounded-xl border border-outline-variant/10 hover:border-primary/30 transition-all group">
            <div class="w-12 h-12 flex items-center justify-center rounded-lg bg-primary/10 text-primary mb-8 group-hover:bg-primary group-hover:text-on-primary transition-all">
              <span class="material-symbols-outlined text-3xl">precision_manufacturing</span>
            </div>
            <h3 class="text-2xl font-headline font-bold mb-4">Smart Innovation</h3>
            <p class="text-on-surface-variant leading-relaxed">IoT-ready panels featuring remote diagnostics and real-time power analytics to optimize your industrial workflow.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Industry Expertise -->
    <section class="py-32">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="mb-20 text-center space-y-4">
          <span class="text-xs font-label text-primary tracking-[0.4em] uppercase">Industry Expertise</span>
          <h2 class="text-5xl md:text-6xl font-headline font-bold tracking-tighter">Precision in Every Sector</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="relative group h-[500px] overflow-hidden rounded-xl">
            <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB3GVvmJ-Fjydf3Ccj9bNvmSNzLW6oeBhzQ_uXj_PHtqk_l7S336D-mMQPQCokiVtxpmxbqkc680odS4N2kvslRPCx9e4ID4EeSNbiVum-R2RYWdy-tyhcs0E2sBG2x1VPRhtyxua7sgYlrK8qSla4CNE-RhPfuQ-ukVrnTD4N175jOHmovRBnHAhDAO5snwHbJewl-S1x5yhtfDOyru6Wp7ZtCu9Zt1L9ltNcVckv010sH35t2UB9Gor-TIMuF8UEedtOyO1lN5Q4" alt="Offshore oil rig at twilight" />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <div class="text-[10px] font-label text-tertiary tracking-widest uppercase mb-2">Hazardous Environments</div>
              <h4 class="text-3xl font-headline font-bold text-white mb-2">Oil &amp; Gas</h4>
              <p class="text-white/60 text-sm opacity-0 group-hover:opacity-100 transition-opacity">Explosion-proof enclosures and high-pressure system controls.</p>
            </div>
          </div>
          <div class="relative group h-[500px] overflow-hidden rounded-xl">
            <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCpFqIfh-4PxaEjeQ6ciLZQywbOpeC_SNpT992JdHnd8h7vn6XPfhIAJwwlxfLpsY1_cQi068SPDZ_bWA06Cut0rZSxvRh3Ld9lDREIRuY28-bO5wSGwW0JgWXKwehcQbvfZvsHg-Z1k3OUZfiyymQ6_ZnZ-T5ZkPw51gSvly3uR7I7d0ow5a5cAwIDnHWYmSjI-LQ2BU5eqGOXIiGtJtOOnfIRShHb6HGy5_fepZ37XR5K7wbiTgdJ1cpfXtCiL1xZsTP65y-Ei28" alt="Robotic manufacturing plant" />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <div class="text-[10px] font-label text-primary tracking-widest uppercase mb-2">Automated Production</div>
              <h4 class="text-3xl font-headline font-bold text-white mb-2">Manufacturing</h4>
              <p class="text-white/60 text-sm opacity-0 group-hover:opacity-100 transition-opacity">Custom PLC logic and high-speed motor control centers.</p>
            </div>
          </div>
          <div class="relative group h-[500px] overflow-hidden rounded-xl">
            <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDG9rXRGxx8zsOB-4WVQSYY-cs1h2hiWHJ5quDjEM4Cg--wMQCKXI8GMuMsT0Q5MJvmMUMySHGqWCqq8x83j2CgCMWb9swC3pX8mS4kx0XCiB2-BltxHgpOsRplOv_g8OsTi9y-jICKuOPMfUxsR1rbgfI4fx9qAp7ajYGU03PidHbO0PN0TzC63VQQnOq0GgTsFQ4t8rf1qET_34h3z2iRTjXuce4Xh8fATFMsGRuE-gwteaL-OvR2pog" alt="Solar panels and wind turbines" />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8 w-full">
              <div class="text-[10px] font-label text-primary tracking-widest uppercase mb-2">Grid Infrastructure</div>
              <h4 class="text-3xl font-headline font-bold text-white mb-2">Energy</h4>
              <p class="text-white/60 text-sm opacity-0 group-hover:opacity-100 transition-opacity">Smart grid synchronization and renewable energy storage panels.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest Intelligence -->
    <section class="py-24 bg-surface-container-low border-y border-outline-variant/10">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="flex justify-between items-center mb-16">
          <h2 class="text-4xl font-headline font-bold">Latest Intelligence</h2>
          <a class="text-primary font-bold flex items-center gap-2 hover:translate-x-1 transition-transform" href="#">
            View All Reports <span class="material-symbols-outlined">trending_flat</span>
          </a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div class="flex flex-col md:flex-row gap-6 group cursor-pointer">
            <div class="w-full md:w-1/2 aspect-video overflow-hidden rounded-lg">
              <img class="w-full h-full object-cover transition-transform group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDufzs7SmlMFPsAHcGfFvW5Z0cNK-7WXqTl4y_vhncQo1HENQGu6syvAqgUk-_LDsBXPUI_mHjTB5F2Pwc5gBpZW2ZLA1eF4lUah22s-lJjcvPbh05s4NiO924DJCaGgUnzAaz2PEMeCKkDVp8HgAiIcehmC2qzezJkwE_RdTBjilsX2-rXOiG15vR2MBjDVeO1wM1vOFnXlqyMLKdM27RQUCB2oeMdovp2WHhJGj97IGWhppgcn6xoHFlLjCTXu4ZP0PXE9hmdbMA" alt="Technician working with circuit board" />
            </div>
            <div class="w-full md:w-1/2 flex flex-col justify-center">
              <span class="text-[10px] font-label text-slate-500 uppercase tracking-widest mb-2">Engineering Brief &bull; MAR 2024</span>
              <h3 class="text-xl font-headline font-bold mb-3 group-hover:text-primary transition-colors">Advancements in Thermal Management for PLC Cabinets</h3>
              <p class="text-on-surface-variant text-sm line-clamp-2">How new active cooling strategies are extending the lifespan of industrial electronics by 30%...</p>
            </div>
          </div>
          <div class="flex flex-col md:flex-row gap-6 group cursor-pointer">
            <div class="w-full md:w-1/2 aspect-video overflow-hidden rounded-lg">
              <img class="w-full h-full object-cover transition-transform group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD4zYtlBfJ29XcqMZn_VmZK9Xh9DnrOU-1uALBt8F2YQ_CM7nhGQhl5dFFSy763N5ryLXC621wovlg4N7lyMAIkJ_T76Nudu3faIh9zMF9-4GIUXdTlt7K4pUmGeS-wp2LpM-T9NI4e0d0y-dgA21H0zKfsV954kZRd771tU_67P7ZxlCzmUCsAAjaq2rpLXdhrIrXpQsF7Ap4ZxXrq-86293h7Z35SlQNOSHKY1Sa7zXvBKCNKB0FDVxgpy1MNsesN8GO6RPDzKzM" alt="Cybersecurity symbols on industrial background" />
            </div>
            <div class="w-full md:w-1/2 flex flex-col justify-center">
              <span class="text-[10px] font-label text-slate-500 uppercase tracking-widest mb-2">Security Report &bull; FEB 2024</span>
              <h3 class="text-xl font-headline font-bold mb-3 group-hover:text-primary transition-colors">Securing Industrial Assets in the IIoT Era</h3>
              <p class="text-on-surface-variant text-sm line-clamp-2">A technical deep-dive into hardware-level security for distributed control networks.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 relative">
      <div class="absolute inset-0 bg-primary/5"></div>
      <div class="max-w-screen-2xl mx-auto px-8 relative z-10">
        <div class="bg-surface-container rounded-3xl p-12 md:p-24 border border-outline-variant/10 text-center space-y-8 overflow-hidden">
          <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <h2 class="text-5xl md:text-7xl font-headline font-bold tracking-tighter">Ready for <span class="text-primary">Precision?</span></h2>
          <p class="text-xl text-on-surface-variant max-w-2xl mx-auto">Our engineering team is ready to review your schematics and provide a comprehensive quote for your next high-impact project.</p>
          <div class="flex flex-wrap justify-center gap-6 pt-6">
            <button class="px-10 py-5 bg-primary-container text-on-primary-container font-bold rounded-md hover:scale-105 transition-transform">
              Start Your Project
            </button>
            <button class="px-10 py-5 bg-surface text-primary border border-primary/20 font-bold rounded-md hover:bg-surface-container-high transition-all">
              Speak to an Engineer
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
